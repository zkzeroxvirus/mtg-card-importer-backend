-- Table-wide format enforcement flag used by object scripts
MTG_ENFORCE_COMMANDER_FORMAT = true

-- Main functionality
function onload()
  if MTG_ENFORCE_COMMANDER_FORMAT == nil then
    MTG_ENFORCE_COMMANDER_FORMAT = true
  end

  buildDataStructure()
  registerObjectGUIDs()
  buildTableButtons()
  addZoneContextMenus()
  Wait.frames(function()
    for _,guid in pairs({'eb479b','cb1610','472648','540e21','ed5aeb','3d4319','876eb2','83ed27'}) do
      pcall(function() getObjectFromGUID(guid).interactable=false end)
    end
  end,10)

  Wait.frames(function()
    for _,guid in pairs({'02e062','de4346','d936a8','b93b40'}) do
      pcall(function() getObjectFromGUID(guid).interactable=true end)
    end
  end,5)

  Hands.disable_unused=false
  Wait.condition(function()
    local Zones=Encoder.call("APIlistZones",{})
    for guid,zone in pairs(Zones) do
      local zoneObj=getObjectFromGUID(guid)
      if zoneObj~=nil then
        local objs=zoneObj.getObjects()
        for _,obj in pairs(objs) do
          if obj.type=='Card' then
            local rot=obj.getRotation()
            rot[3]=180
            obj.setRotation(rot)
          end
        end
      end
    end
  end,function() return Encoder~=nil end)

end

