end

function onMerchantGlobalPackButton(player, value, id)
  local packType, costString, label = string.match(value or "", "^([^|]+)|([^|]+)|(.+)$")
  if packType and costString and label then
    onTownBuildingGlobalOption(player, "MERCHANT|" .. packType .. "|" .. costString .. "|" .. label, id)
    return
  end

  onTownBuildingGlobalOption(player, value, id)
end
