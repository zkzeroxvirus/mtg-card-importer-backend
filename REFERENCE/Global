-- zone specific context menu items
function onObjectEnterZone(zone,obj)
  if obj==nil or not(obj.type=='Card' or obj.type=='Deck') then return end
  if obj.getName():lower():find('planechase') then return end

  local guid=obj.getGUID()
  if contextMenuDebounce[guid] then return end
  contextMenuDebounce[guid]=true

  Wait.frames(function()
    contextMenuDebounce[guid]=nil
    if obj==nil or not(obj.type=='Card' or obj.type=='Deck') then return end

    local inHandZone=false
    local inPlayZone=false
    local inLibrZone=false

    local objZones=obj.getZones() or {}
    local encZones=nil
    if Encoder~=nil then
      encZones=Encoder.call("APIlistZones",{})
    end

    for _,oZone in pairs(objZones) do
      if encZones then
        local encZone=encZones[oZone.getGUID()]
        if encZone and encZone.name:match('_1') then
          inHandZone=true
        end
      end
      for _,col in pairs(Player.getAvailableColors()) do
        if data[col] then
          if oZone==data[col]["playmat"] then
            inPlayZone=true
          end
          if oZone==data[col]["libraryZone"] then
            inLibrZone=true
          end
        end
      end
    end

    local state=(inHandZone and '1' or '0')..(inPlayZone and '1' or '0')..(inLibrZone and '1' or '0')
    if contextMenuState[guid]==state then return end
    contextMenuState[guid]=state

    if not(inHandZone or inPlayZone or inLibrZone) then return end

    obj.clearContextMenu()
    if obj.type=='Card' then
      if obj.getDescription():lower():find('morph') then
        obj.addContextMenuItem('Morph',cardMorph)
      end
    end
    if obj.type=='Card' and inPlayZone then
      obj.addContextMenuItem('Make Token Copy',cardToken)
      if obj.getDescription():lower():find('cascade') then
        obj.addContextMenuItem('Cascade',cardCascade)
      end
    end
    if obj.type=='Card' and inHandZone then
      obj.addContextMenuItem('Sort Hand by CMC',sortHands)
      obj.addContextMenuItem('Random Discard',randomDiscard)
    end
    if obj.type=='Deck' and inLibrZone then
      obj.addContextMenuItem('Cascade for X',deckCascade)
      obj.addContextMenuItem('Reveal until Type',deckSeachType)
      addLandContextMenus(obj)
      obj.setScale({1,1,1})
    end
  end,1)
end

