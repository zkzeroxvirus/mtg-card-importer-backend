function show(obj, color, alt)
	if obj.getName() == "MTG Counter" then
		visibleOpenRules(color, color .. "Counter")
	end
end

function close(player, value, id)
	if id == "bcCloseButton" then
		visibleCloseRules(player, player.color .. "Counter")
	end
end

function visibleOpenRules(color, id)
	if color ~= "Grey" then
		local active = UI.getAttribute(id, "active")
		local visibleColors = UI.getAttribute(id, "visibility")
		if visibleColors == "" then
			UI.setAttribute(id, "visibility", color)
		else
			if string.find(visibleColors, color) == nil then
				visibleColors = visibleColors .. "|" .. color
				UI.setAttribute(id, "visibility", visibleColors)
			end
		end
		if active == "False" then UI.setAttribute(id, "active", "True") end
	end
end

function visibleCloseRules(player, id)
	local visibleColors = UI.getAttribute(id, "visibility")
	if visibleColors == player.color then UI.setAttribute(id, "active", "False") end
	if visibleColors == player.color then
		UI.setAttribute(id, "visibility", "")
	else
		local colorTbl = {}
		for i in string.gmatch(visibleColors, "[^|]+") do
			if i ~= player.color then
   				table.insert(colorTbl, i)
			end
		end
		visibleColors = table.concat(colorTbl, "|")
		UI.setAttribute(id, "visibility", visibleColors)
	end
end

-- Town building screen-space UI (opened by building world buttons).
local TOWN_BUILDING_PANEL_BY_KEY = {
  BLACKSMITH = "town_blacksmith_panel",
  MERCHANT = "town_merchant_panel",
  MYSTIC = "town_mystic_panel",
  CASINO = "town_casino_panel",
  CASTLE = "town_castle_panel",
  CATHEDRAL = "town_cathedral_panel",
  BANK = "town_bank_panel",
  PORTAL = "town_portal_panel",
  TAVERN = "town_tavern_panel",
  TRADING_POST = "town_trading_post_panel",
}
townBuildingUIContextByPlayer = townBuildingUIContextByPlayer or {}

local function splitVisibilityColors(visibility)
  local colors = {}
  if not visibility or visibility == "" then
    return colors
  end

  for color in string.gmatch(visibility, "[^|]+") do
    table.insert(colors, color)
  end

  return colors
end

local function setVisibilityColors(id, colors)
  if #colors == 0 then
    UI.setAttribute(id, "visibility", "")
    UI.setAttribute(id, "active", "False")
    return
  end

  table.sort(colors)
  UI.setAttribute(id, "visibility", table.concat(colors, "|"))
  UI.setAttribute(id, "active", "True")
end

local function addViewerColor(panelId, playerColor)
  local visibleColors = splitVisibilityColors(UI.getAttribute(panelId, "visibility"))
  for _, color in ipairs(visibleColors) do
    if color == playerColor then
      setVisibilityColors(panelId, visibleColors)
      return
    end
  end

  table.insert(visibleColors, playerColor)
  setVisibilityColors(panelId, visibleColors)
end

local function removeViewerColor(panelId, playerColor)
  local visibleColors = splitVisibilityColors(UI.getAttribute(panelId, "visibility"))
  local keptColors = {}
  for _, color in ipairs(visibleColors) do
    if color ~= playerColor then
      table.insert(keptColors, color)
    end
  end

  setVisibilityColors(panelId, keptColors)
end

local function playerCanSeePanel(panelId, playerColor)
  local visibleColors = splitVisibilityColors(UI.getAttribute(panelId, "visibility"))
  for _, color in ipairs(visibleColors) do
    if color == playerColor then
      return true
    end
  end

  return false
end

function toggleTownBuildingUI(params)
  if type(params) ~= "table" then
    return
  end

  local playerColor = params.playerColor
  local buildingGUID = params.buildingGUID
  local buildingKey = params.buildingKey
  local panelId = TOWN_BUILDING_PANEL_BY_KEY[buildingKey]
  if not playerColor or playerColor == "Grey" or not buildingGUID or not panelId then
    return
  end

  local existingContext = townBuildingUIContextByPlayer[playerColor]
  if existingContext
    and existingContext.panelId == panelId
    and existingContext.buildingGUID == buildingGUID
    and playerCanSeePanel(panelId, playerColor)
  then
    closeTownBuildingUI({ playerColor = playerColor })
    return
  end

  if existingContext and existingContext.panelId then
    removeViewerColor(existingContext.panelId, playerColor)
  end

  townBuildingUIContextByPlayer[playerColor] = {
    buildingGUID = buildingGUID,
    buildingKey = buildingKey,
    panelId = panelId,
  }
  addViewerColor(panelId, playerColor)
end

function closeTownBuildingUI(params)
  if type(params) ~= "table" then
    return
  end

  local playerColor = params.playerColor
  if not playerColor then
    return
  end

  local context = townBuildingUIContextByPlayer[playerColor]
  if context and context.panelId then
    removeViewerColor(context.panelId, playerColor)
  end
  townBuildingUIContextByPlayer[playerColor] = nil
end

function onTownBuildingGlobalClose(player, _value, _id)
  closeTownBuildingUI({ playerColor = player.color })
end

function onTownBuildingGlobalOption(player, value, id)
  local buildingKey, optionKey, costString, label = string.match(value or "", "^([^|]+)|([^|]+)|([^|]+)|(.+)$")
  local cost = tonumber(costString)
  if not buildingKey or not optionKey or not cost or not label then
    printToColor("Town building option is invalid.", player.color, { 1, 0.3, 0.3 })
    return
  end

  local context = townBuildingUIContextByPlayer[player.color]
  if not context then
    printToColor("No building context found. Click the building again.", player.color, { 1, 0.3, 0.3 })
    return
  end

  if context.buildingKey ~= buildingKey then
    printToColor("Building context mismatch. Click the building again.", player.color, { 1, 0.3, 0.3 })
    return
  end

  local buildingObj = getObjectFromGUID(context.buildingGUID)
  if not buildingObj then
    printToColor("Building object is no longer available.", player.color, { 1, 0.3, 0.3 })
    closeTownBuildingUI({ playerColor = player.color })
    return
  end

  buildingObj.call("onTownBuildingGlobalOption", {
    playerColor = player.color,
    buildingKey = buildingKey,
    optionKey = optionKey,
    cost = cost,
    label = label,
    buttonId = id,
    rawValue = value,
  })
end

-- Backward-compatible Merchant wrappers.
function toggleMerchantScreenUI(params)
