# Server Configuration
PORT=3000
NODE_ENV=development

# Clustering Configuration
# Number of worker processes (default: auto = CPU cores, capped by container memory)
# Set to 1 to disable clustering
WORKERS=auto

# Delay in milliseconds between worker startup in cluster mode
STARTUP_STAGGER_MS=500

# Performance Configuration
# Maximum size for in-memory caches (failed queries, error tracking)
MAX_CACHE_SIZE=5000

# Bulk query cache controls (only used when USE_BULK_DATA=true)
# Maximum number of cached query pools retained in memory
BULK_QUERY_CACHE_SIZE=200
# Time-to-live for cached query pools in milliseconds
BULK_QUERY_CACHE_TTL_MS=60000
# Skip caching query pools larger than this many cards (prevents giant retained arrays)
BULK_QUERY_CACHE_MAX_ENTRY_CARDS=1500

# Maximum deck size accepted by /deck and /build endpoints
MAX_DECK_SIZE=500

# Maximum cards accepted by /random and /random/build (default fallback: MAX_DECK_SIZE)
MAX_RANDOM_COUNT=500

# Scryfall API Configuration
# Delay in milliseconds between Scryfall API requests (recommended: 100ms)
SCRYFALL_DELAY=100

# Image proxy cache configuration
# Persistent disk cache for proxied Scryfall images (shared across restarts)
IMAGE_PROXY_CACHE_DIR=./data/image-cache
# In-memory cache TTL for proxy lookups in milliseconds
IMAGE_PROXY_CACHE_TTL_MS=86400000
# Maximum number of in-memory proxy cache entries
IMAGE_PROXY_CACHE_MAX_SIZE=2000
# Maximum total bytes allowed for in-memory image cache (default: 512MB)
IMAGE_PROXY_CACHE_MAX_BYTES=536870912
# Upstream fetch timeout for image downloads in milliseconds
IMAGE_PROXY_TIMEOUT_MS=15000
# Maximum total bytes allowed on disk for cached image binaries (default: 5GB)
IMAGE_PROXY_DISK_MAX_BYTES=5368709120
# Minimum time between disk cache cleanup passes in milliseconds
IMAGE_PROXY_DISK_CLEANUP_INTERVAL_MS=300000
# Public base URL used when generating image-proxy links for TTS payloads.
# Set this to your internet-facing API or image host, not localhost.
IMAGE_PROXY_BASE_URL=https://api.mtginfo.org

# Scryfall rate-limit mode:
# - always (default): throttle every outbound Scryfall API request for strict compliance
# - never: disable queue throttling (not recommended; can violate Scryfall guidelines)
SCRYFALL_RATE_LIMIT_MODE=always

# Card Back URL
DEFAULT_CARD_BACK=https://steamusercontent-a.akamaihd.net/ugc/1647720103762682461/35EF6E87970E2A5D6581E7D96A99F8A575B7A15F/

# Bulk Data Configuration
# Set to 'true' to enable bulk data mode (recommended for Unraid/self-hosted)
# Set to 'false' to use Scryfall API mode (required for serverless/Render free tier)
USE_BULK_DATA=true

# Bulk data storage path (only used when USE_BULK_DATA=true)
# Default: ./data (relative to project root)
# For Docker: /app/data (mount a volume here)
BULK_DATA_PATH=/app/data

# Bulk data dataset (only used when USE_BULK_DATA=true)
# oracle_cards is smaller and faster; default_cards includes prices (usd/eur/tix) and all printings.
BULK_DATA_TYPE=default_cards

# Include rulings bulk data download/cache (increases disk/memory usage)
BULK_INCLUDE_RULINGS=false

# Scheduled bulk update behavior
# false (default): memory-safe reload, avoids old+new dataset overlap during scheduled refresh
# true: keep old dataset in memory for rollback on reload failure (higher peak memory)
BULK_SCHEDULED_UPDATE_KEEP_OLD_DATA=false
